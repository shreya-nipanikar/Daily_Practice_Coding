package com.corejava.dayTwoAssignments;

public class Manager extends EmployeeSystem{
	
	String deptName;
	double bonus;

	public Manager(int employeeId, String name, double salary,
			String deptName, double bonus) {
		super(employeeId, name, salary);
		this.deptName = deptName;
		this.bonus = bonus;
		
	}
	
	void displaySalary() {
		bonus = bonus + salary;
		System.out.println("Manager's Salary : "+bonus);
		
	}
	
}

